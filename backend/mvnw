if [ -z "$MAVEN_SKIP_RC" ]; then
  if [ -f /usr/local/etc/mavenrc ]; then
    . /usr/local/etc/mavenrc
  fi
  if [ -f /etc/mavenrc ]; then
    . /etc/mavenrc
  fi
  if [ -f "$HOME/.mavenrc" ]; then
    . "$HOME/.mavenrc"
  fi
fi

cygwin=false
darwin=false
mingw=false
case "$(uname)" in
  CYGWIN*) cygwin=true ;;
  MINGW*) mingw=true ;;
  Darwin*)
    darwin=true
    if [ -z "$JAVA_HOME" ]; then
      if [ -x "/usr/libexec/java_home" ]; then
        JAVA_HOME="$(/usr/libexec/java_home)"
        export JAVA_HOME
      else
        JAVA_HOME="/Library/Java/Home"
        export JAVA_HOME
      fi
    fi
    ;;
esac

if [ -z "$JAVA_HOME" ]; then
  javaExecutable="$(which javac)"
  if [ -n "$javaExecutable" ] && ! [ "$(expr "$javaExecutable" : '\([^ ]*\)')" = "no" ]; then
    readLink=$(which readlink 2>/dev/null)
    if [ -n "$readLink" ]; then
      if $darwin; then
        javaHome="$(dirname "$javaExecutable")"
        JAVA_HOME="$(cd "$javaHome" && pwd -P)"
      else
        JAVA_HOME="$(dirname "$(readlink -f "$javaExecutable")")"
        JAVA_HOME=$(expr "$JAVA_HOME" : '\(.*\)/bin')
      fi
      export JAVA_HOME
    fi
  fi
fi

if [ -z "$JAVACMD" ]; then
  if [ -n "$JAVA_HOME" ]; then
    if [ -x "$JAVA_HOME/jre/sh/java" ]; then
      JAVACMD="$JAVA_HOME/jre/sh/java"
    else
      JAVACMD="$JAVA_HOME/bin/java"
    fi
  else
    JAVACMD="$(command -v java)"
  fi
fi

if [ ! -x "$JAVACMD" ]; then
  echo "Error: JAVA_HOME is not defined correctly or java not found." >&2
  exit 1
fi

find_maven_basedir() {
  if [ -z "$1" ]; then
    echo "Path not specified to find_maven_basedir" >&2
    return 1
  fi
  basedir="$1"
  wdir="$1"
  while [ "$wdir" != '/' ]; do
    if [ -d "$wdir/.mvn" ]; then
      basedir=$wdir
      break
    fi
    if [ -d "${wdir}" ]; then
      wdir="$(cd "$wdir/.." && pwd)"
    fi
  done
  printf '%s' "$(cd "$basedir" && pwd)"
}

BASE_DIR=$(find_maven_basedir "$(dirname "$0")")
[ -z "$BASE_DIR" ] && exit 1

MAVEN_PROJECTBASEDIR=${MAVEN_BASEDIR:-"$BASE_DIR"}
export MAVEN_PROJECTBASEDIR

wrapperJarPath="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
if [ ! -r "$wrapperJarPath" ]; then
  trim() { printf "%s" "${1}" | tr -d '[:space:]'; }
  wrapperUrl=""
  if [ -f "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties" ]; then
    while IFS="=" read -r key value; do
      case "$key" in wrapperUrl) wrapperUrl=$(trim "${value}"); break ;; esac
    done <"$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"
  fi
  [ -z "$wrapperUrl" ] && wrapperUrl="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"
  if command -v curl >/dev/null; then
    curl -sL -o "$wrapperJarPath" "$wrapperUrl" -f || rm -f "$wrapperJarPath"
  elif command -v wget >/dev/null; then
    wget -q -O "$wrapperJarPath" "$wrapperUrl" || rm -f "$wrapperJarPath"
  else
    echo "Need curl or wget to download Maven wrapper jar." >&2
    exit 1
  fi
  [ ! -r "$wrapperJarPath" ] && echo "Failed to download maven-wrapper.jar" >&2 && exit 1
fi

MAVEN_OPTS="${MAVEN_OPTS:--Xmx512m}"
export MAVEN_CMD_LINE_ARGS="$MAVEN_CONFIG $*"

exec "$JAVACMD" \
  $MAVEN_OPTS \
  -classpath "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar" \
  "-Dmaven.multiModuleProjectDirectory=${MAVEN_PROJECTBASEDIR}" \
  org.apache.maven.wrapper.MavenWrapperMain $MAVEN_CONFIG "$@"
